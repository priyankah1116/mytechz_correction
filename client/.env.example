# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Django Backend API
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:5010

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email Controls
BLOCK_DISPOSABLE_EMAILS=true

# Contact form SMTP (e.g. Gmail app password, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MyTechZ Contact <no-reply@mytechz.com>"
# CONTACT_TO_EMAIL=contact@mytechz.com

# Social
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/mytechz

# Floating AI Chat (server-only — never expose to client)
AI_PROVIDER=groq                          # 'groq' or 'anthropic'
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
AI_MODEL_FAST=llama-3.3-70b-versatile
AI_MODEL_SMART=llama-3.3-70b-versatile
AI_RATE_LIMIT_PER_MIN=12

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=
